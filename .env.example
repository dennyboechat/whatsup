# OpenAI (required for summarization)
OPENAI_API_KEY=

# Optional: path to Chrome/Chromium/Edge if Puppeteer's bundled browser is missing
# (defaults to standard locations e.g. /Applications/Google Chrome.app/... on macOS)
# PUPPETEER_EXECUTABLE_PATH=

# WhatsApp: default group title (matched case-insensitively). Override at runtime: REPL command `group <name>`
TARGET_GROUP_NAME=

# Summarize: prefer text messages from the last N hours (default 24). If none, use the last M messages.
SUMMARY_WINDOW_HOURS=24
SUMMARY_FALLBACK_MESSAGES=50
# Upper bound while loading history to fill the window (default 2000); raise for very active groups.
SUMMARY_MAX_FETCH_MESSAGES=2000

# OpenAI model (must support JSON mode)
OPENAI_MODEL=gpt-4o-mini

# API resilience
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_BASE_MS=1000
OPENAI_MIN_REQUEST_INTERVAL_MS=500
